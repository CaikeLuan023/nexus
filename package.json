{
    "name": "nexus",
    "version": "1.0.0",
    "description": "Nexus - Sistema de gestao para provedores de internet",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "test": "jest",
        "lint": "eslint . --ext .js",
        "lint:fix": "eslint . --ext .js --fix",
        "format": "prettier --write \"**/*.{js,json,css,md}\"",
        "format:check": "prettier --check \"**/*.{js,json,css,md}\""
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "dotenv": "^16.4.0",
        "express": "^4.21.0",
        "express-rate-limit": "^8.3.1",
        "express-session": "^1.19.0",
        "helmet": "^8.1.0",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^8.0.2",
        "otplib": "^13.3.0",
        "pdfkit": "^0.17.2",
        "sql.js": "^1.11.0",
        "xlsx": "^0.18.5"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.js"
        ]
    },
    "devDependencies": {
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "jest": "^30.3.0",
        "prettier": "^3.8.1"
    }
}
